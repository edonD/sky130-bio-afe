{
  "name": "SKY130 Programmable Gain Amplifier v2",
  "description": "Simplified: 1-64x in 4 steps. Sigma-delta ADC handles more dynamic range so PGA needs less.",
  "supply_v": 1.8,
  "margin_rule": "Every spec must pass with >= 25% margin",
  "measurements": {
    "gain_settings": {
      "target": ">=4",
      "weight": 15,
      "unit": "settings",
      "description": "Gain steps: 1, 4, 16, 64 (binary, 4 steps)"
    },
    "gain_error_pct": {
      "target": "<0.5",
      "weight": 20,
      "unit": "%",
      "description": "Tighter gain accuracy for 20-bit signal chain"
    },
    "bandwidth_hz": {
      "target": ">10000",
      "weight": 15,
      "unit": "Hz",
      "description": "-3 dB BW at max gain (64x)"
    },
    "output_noise_uvrms": {
      "target": "<30",
      "weight": 15,
      "unit": "uVrms",
      "description": "Output noise at gain=1, 0.5-150 Hz"
    },
    "thd_pct": {
      "target": "<0.01",
      "weight": 15,
      "unit": "%",
      "description": "Tighter THD for 20-bit signal chain (was <0.1%)"
    },
    "power_uw": {
      "target": "<30",
      "weight": 10,
      "unit": "uW",
      "description": "Relaxed from v1 (<10) for better linearity"
    },
    "settling_time_us": {
      "target": "<100",
      "weight": 10,
      "unit": "us",
      "description": "Settling after gain change"
    }
  }
}
